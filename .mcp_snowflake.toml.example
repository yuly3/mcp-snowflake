# MCP Snowflake configuration file example
# Copy this file to .mcp_snowflake.toml and use it

[snowflake]
account = "your-account.region"
user = "your-username"
# password = "your-password"  # Required only when authenticator = "SNOWFLAKE"
warehouse = "your-warehouse"  # Optional
role = "your-role"  # Optional
# secondary_roles = ["analyst_role", "bi_reader_role"]  # Optional: apply USE SECONDARY ROLES per session
# secondary_roles = ["NONE"]  # Optional: explicitly disable secondary roles per session
authenticator = "externalbrowser"  # "SNOWFLAKE" or "externalbrowser"
client_store_temporary_credential = true  # ID token cache for externalbrowser

# [tools]
# Enable/disable specific tools (all enabled by default)
# analyze_table_statistics = true
# describe_table = true
# execute_query = true
# list_databases = true
# list_schemas = true
# list_tables = true
# profile_semi_structured_columns = true
# sample_table_data = true
# search_columns = true

# [execute_query]
# Default timeout_seconds when not specified by the caller
# timeout_seconds_default = 30  # Optional (must be <= timeout_seconds_max)
# Maximum value accepted by execute_query.timeout_seconds
# timeout_seconds_max = 300  # Optional (max: 3600)

# [analyze_table_statistics]
# Timeout for analyze_table_statistics query
# query_timeout_seconds = 60  # Optional (max: 3600)

# [describe_table]
# Timeout for describe_table query
# query_timeout_seconds = 10  # Optional (max: 3600)

# [list_databases]
# Timeout for list_databases query
# query_timeout_seconds = 10  # Optional (max: 3600)

# [list_schemas]
# Timeout for list_schemas query
# query_timeout_seconds = 10  # Optional (max: 3600)

# [list_tables]
# Timeout for list_tables query
# query_timeout_seconds = 10  # Optional (max: 3600)

# [profile_semi_structured_columns]
# Timeouts for semi-structured profiling queries
# base_query_timeout_seconds = 90   # Optional (max: 3600)
# path_query_timeout_seconds = 180  # Optional (max: 3600, must be >= base_query_timeout_seconds)

# [sample_table_data]
# Timeout for sample_table_data query
# query_timeout_seconds = 60  # Optional (max: 3600)

# [search_columns]
# Timeout for search_columns query
# query_timeout_seconds = 30  # Optional (max: 3600)
